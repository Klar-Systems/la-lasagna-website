# Reservation form email settings — set these in the Vercel dashboard
# (Project → Settings → Environment Variables). Do NOT commit real values.
#
# Uses Resend (https://resend.com). Free tier: ~3,000 emails/month.
# 1. Sign up, create an API key: https://resend.com/api-keys
# 2. Verify the domain lalasagnahelsinki.com: https://resend.com/domains
#    (add the DNS records Resend shows to the domain registrar), then use a
#    From address on that domain, e.g. reservations@lalasagnahelsinki.com.
RESEND_API_KEY=__resend_api_key_here__
# Where reservation emails are delivered
BOOKING_TO=lalasagnahelsinki@gmail.com
# Verified sender. Before the domain is verified you can omit this and the
# code falls back to Resend's test address (onboarding@resend.dev), which can
# only deliver to the Resend account owner's email — fine for first testing.
BOOKING_FROM="La Lasagna <reservations@lalasagnahelsinki.com>"
