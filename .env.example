# Reservation form SMTP settings — set these in the Vercel dashboard
# (Project → Settings → Environment Variables). Do NOT commit real values.
#
# Configured for the restaurant's existing Gmail (lalasagnahelsinki@gmail.com).
# IMPORTANT: Gmail requires a 16-character "App Password" (not the normal
# account password), and 2-Step Verification must be ON for the account.
# Create one at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=lalasagnahelsinki@gmail.com
SMTP_PASS=__gmail_app_password_here__
# Where reservation emails are delivered
BOOKING_TO=lalasagnahelsinki@gmail.com
# From address shown on the email (kept as the Gmail so Gmail accepts it)
BOOKING_FROM=lalasagnahelsinki@gmail.com
