# Reservation form SMTP settings — set these in the Vercel dashboard
# (Project → Settings → Environment Variables). Do NOT commit real values.
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
# SMTP_SECURE=true   # only for port 465 (implicit TLS); leave unset for 587 STARTTLS
SMTP_USER=lalasagnahelsinki@example.com
SMTP_PASS=__set_in_vercel__
# Where reservation emails are delivered (defaults to SMTP_USER if unset)
BOOKING_TO=lalasagnahelsinki@gmail.com
# Optional From address (defaults to SMTP_USER if unset)
# BOOKING_FROM=lalasagnahelsinki@example.com
